# Ollama connection (host machine running Ollama)
# Change if Ollama is on a different host or port
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Model names — must match what you have pulled in Ollama
TEXT_MODEL=qwen2.5:7b-instruct
VISION_MODEL=llama3.2-vision:11b
EMBED_MODEL=nomic-embed-text

# Set to "true" to enable multimodal (vision) summarisation
ENABLE_VISION=false

# Qdrant collection name
COLLECTION_NAME=rag_docs
